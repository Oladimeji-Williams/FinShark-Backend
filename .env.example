# FinShark Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env file with real secrets

# Database Connection String
# For Production: Use managed identity or service principal with Azure SQL
# For Development: Use LocalDB (appsettings.Development.json instead)
FINSHARK_DB_CONNECTION=Server=(localdb)\\mssqllocaldb;Database=FinSharkDb;Trusted_Connection=true;Encrypt=false;

# Application Settings
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000

# Logging Level
LOGGING_LEVEL=Information

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Key Vault (optional, for Azure Key Vault integration)
# AZURE_KEYVAULT_ENDPOINT=https://your-vault.vault.azure.net/

# Database Retry Policy
DB_MAX_RETRIES=3
DB_RETRY_DELAY_SECONDS=30
