# FinShark Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env file with real secrets

# Database Connection String
FINSHARK_DB_CONNECTION=Server=YOUR_SERVER;Database=FinSharkDB;Trusted_Connection=true;Encrypt=false;

# Application Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000

# Logging Level
LOGGING_LEVEL=Information

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Database Retry Policy
DB_MAX_RETRIES=3
DB_RETRY_DELAY_SECONDS=30

# JWT
Jwt__Key=YOUR_JWT_SECRET_KEY
Jwt__Issuer=FinShark
Jwt__Audience=FinSharkUsers
Jwt__ExpiryInMinutes=60

# SMTP (provider: Mailtrap or Gmail)
Smtp__Provider=Mailtrap
Smtp__Host=smtp.mailtrap.io
Smtp__Port=2525
Smtp__EnableSsl=true
Smtp__UseDefaultCredentials=false
Smtp__UserName=YOUR_MAILTRAP_USERNAME
Smtp__Password=YOUR_MAILTRAP_PASSWORD
Smtp__FromEmail=no-reply@finshark.local
Smtp__FromName=FinShark

# For Gmail, set:
# Smtp__Provider=Gmail
# Smtp__Host=smtp.gmail.com
# Smtp__Port=587
# Smtp__EnableSsl=true
# Smtp__UseDefaultCredentials=false
# Smtp__UserName=your-gmail-username
# Smtp__Password=your-app-password
# Smtp__FromEmail=your-gmail-address
# Smtp__FromName=FinShark

# App Settings
AppSettings__ClientUrl=https://localhost:5001

# Production Mailtrap SMTP
# For production set your production Mailtrap account values.
Smtp__Host=smtp.mailtrap.io
Smtp__Port=587
Smtp__EnableSsl=true
Smtp__UseDefaultCredentials=false
Smtp__UserName=YOUR_MAILTRAP_PROD_USERNAME
Smtp__Password=YOUR_MAILTRAP_PROD_PASSWORD
Smtp__FromEmail=no-reply@yourdomain.com
Smtp__FromName=FinShark