{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=FinSharkDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:3000,http://localhost:4200,https://localhost:3001,https://localhost:4201",
    "AllowAllMethods": "true",
    "AllowAllHeaders": "true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "AppSettings": {
    "ClientUrl": "https://localhost:5001"
  },
  "FMP": {
    "BaseUrl": "https://financialmodelingprep.com",
    "ApiKey": "YOUR_FMP_API_KEY",
    "TimeoutSeconds": 30
  },
  "Smtp": {
    "Provider": "Mailtrap",
    "Host": "smtp.mailtrap.io",
    "Port": 2525,
    "EnableSsl": true,
    "UseDefaultCredentials": false,
    "FromEmail": "no-reply@finshark.local",
    "FromName": "FinShark"
  }
}
