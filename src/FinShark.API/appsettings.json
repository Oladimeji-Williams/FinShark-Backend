{
  "Cors": {
    "AllowedOrigins": "*",
    "AllowAllMethods": "true",
    "AllowAllHeaders": "true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyHereThatIsAtLeast32CharactersLongForHS256",
    "Issuer": "FinShark",
    "Audience": "FinSharkUsers",
    "ExpiryInMinutes": 60
  },
  "AppSettings": {
    "ClientUrl": "https://localhost:5001"
  },
  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "EnableSsl": true,
    "FromEmail": "noreply@example.com",
    "FromName": "FinShark"
  },
  "AllowedHosts": "*"
}
